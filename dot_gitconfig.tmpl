{{- if not .headless }}
[user]
name = "andrew nguyen"
email = "ngphuchoanganh@gmail.com"
{{- end }}

{{- if and (eq .chezmoi.os "linux") (output "uname" "-r" | lower | contains "microsoft") }}
[credential]
		helper = "/mnt/c/Users/{{ .win_user }}/scoop/root/apps/git/current/mingw64/bin/git-credential-manager.exe"
{{- end }}

[core]
	pager = diff-so-fancy | less --tabs=4 -RF
[interactive]
	diffFilter = diff-so-fancy --patch
[diff]
	tool = nvim
[difftool "nvim"]
	cmd = "nvim -d \"$LOCAL\" \"$REMOTE\""
[merge]
	tool = nvim
[mergetool "nvim"]
	cmd = "nvim -d \"$LOCAL\" \"$REMOTE\" -c \"botright split $MERGED\" -c \"set diff\""
	trustExitCode = false
	keepBackup = false
