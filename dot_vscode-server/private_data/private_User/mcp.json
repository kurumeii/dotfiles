{
  "servers": {
    "wsl-serena": {
      "type": "http",
      "url": "http://localhost:12345/mcp"
    },
    "wsl-context-7": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["dlx", "@upstash/context7-mcp"],
      "env": {
        "api-key": "$CONTEXT_7_API_KEY"
      }
    },
    "wsl-figma": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["dlx", "figma-developer-mcp", "--stdio"],
      "env": {
        "FIGMA_API_KEY": "$FIGMA_API_KEY"
      }
    },
    "wsl-React-Aria": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["dlx", "@react-aria/mcp@latest"]
    }
  },
  "inputs": []
}
