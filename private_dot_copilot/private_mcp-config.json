{
	"mcpServers": {
		"figma": {
			"tools": [
				"*"
			],
			"type": "local",
			"command": "pnpm",
			"args": [
				"dlx",
				"figma-developer-mcp",
				"--stdio"
			],
			"env": {
				"FIGMA_API_KEY": "${FIGMA_API_KEY}"
			}
		},
		"shadcn": {
			"tools": [
				"*"
			],
			"type": "local",
			"command": "pnpm",
			"args": [
				"dlx",
				"shadcn@latest",
				"mcp"
			]
		},
		"context-7": {
			"tools": [
				"*"
			],
			"type": "local",
			"command": "pnpm",
			"args": [
				"dlx",
				"@upstash/context7-mcp"
			],
			"env": {
				"api-key": "${CONTEXT_7_API_KEY}"
			}
		},
		"serena": {
			"type": "http",
			"url": "http://localhost:12345/mcp",
			"headers": {},
			"tools": [
				"*"
			]
		},
		"tavily": {
			"tools": [
				"*"
			],
			"command": "pnpm",
			"args": [
				"dlx",
				"tavily-mcp@latest"
			],
			"env": {
				"TAVILY_API_KEY": "${TAVILY_API_KEY}"
			}
		}
	}
}
