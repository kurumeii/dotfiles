{
	"Console Log": {
		"prefix": "clg",
		"body": "console.log('$1:', $1);",
		"description": "Log a variable to the console"
	},
	"Console error": {
		"prefix": "cer",
		"body": "console.error('$1:');",
		"description": "Console error"
	},
	"Try Catch Block": {
		"prefix": [
			"trc",
			"tryc",
			"trycatch"
		],
		"body": [
			"try {",
			"\t$1",
			"} catch (error) {",
			"\tconsole.error('${2:Error}:', error);",
			"}"
		],
		"description": "Try Catch Block"
	},
	"React Functional Component": {
		"prefix": "rfc",
		"body": [
			"export const ${1:ComponentName} = (${2:props}) => {",
			"\treturn (",
			"\t\t<div>",
			"\t\t\t$3",
			"\t\t</div>",
			"\t);",
			"};",
		],
		"description": "React Functional Component"
	}
}
