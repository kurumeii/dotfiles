vim.g.mapleader = " "
vim.g.maplocalleader = "\\"
vim.g.show_dotfiles = true

vim.o.number = true
vim.o.relativenumber = true
vim.o.mouse = "a"
vim.o.showmode = false
vim.o.switchbuf = "usetab"
-- Set to true if you have a Nerd Font installed and selected in the terminal
vim.g.have_nerd_font = true
{{- $isWSL := false -}}
{{- if eq .chezmoi.os "linux" -}}
{{-   if (output "uname" "-r" | lower | contains "microsoft") -}}
{{-     $isWSL = true -}}
{{-   end -}}
{{- end -}}

{{- if $isWSL }}
vim.g.clipboard = {
	name = "Win32Yank",
	copy = {
		["+"] = "/mnt/c/Users/{{ .win_user }}/scoop/root/shims/win32yank.exe -i --crlf",
		["*"] = "/mnt/c/Users/{{ .win_user }}/scoop/root/shims/win32yank.exe -i --crlf",
	},
	paste = {
		["+"] = "/mnt/c/Users/{{ .win_user }}/scoop/root/shims/win32yank.exe -o --lf",
		["*"] = "/mnt/c/Users/{{ .win_user }}/scoop/root/shims/win32yank.exe -o --lf",
	},
}

vim.ui.open = function(path)
	local script = vim.fn.expand("$HOME/bin/open-in-windows")
	if vim.fn.executable(script) == 1 then
		vim.fn.jobstart({ script, path }, { detach = true })
	else
		vim.notify("open-in-windows script not found", vim.log.levels.WARN)
	end
end
{{- end }}
vim.o.clipboard = "unnamedplus"

{{- if eq .chezmoi.os "windows" -}}
vim.o.shell = "pwsh"
{{- else if eq .chezmoi.os "linux" -}}
vim.o.shell = "zsh"
{{- end}}
vim.o.smartcase = true
vim.o.smartindent = true
vim.o.ignorecase = true
vim.o.breakindent = true
vim.o.inccommand = "nosplit"
vim.o.foldlevel = 99 -- Necessary
vim.o.foldlevelstart = 99
vim.o.splitright = true
vim.o.splitbelow = true
vim.o.cmdheight = 1
vim.o.laststatus = 2
vim.o.signcolumn = "yes"
vim.o.wrap = false
vim.o.tabstop = 2
vim.o.shiftwidth = 2
vim.o.cursorline = true
vim.o.confirm = true
vim.o.formatoptions = "jcroqlnt" -- tcqj
vim.o.grepformat = "%f:%l:%c:%m"
vim.o.grepprg = "rg --vimgrep"
vim.o.scrolloff = 3
